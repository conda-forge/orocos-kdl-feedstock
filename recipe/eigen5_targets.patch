From 9d4131c3768209213414fc83f596847dc0b8b36c Mon Sep 17 00:00:00 2001
From: John Wason <wason@wasontech.com>
Date: Tue, 5 May 2026 11:47:18 -0400
Subject: [PATCH] eigen5 targets

---
 orocos_kdl/CMakeLists.txt             | 6 +-----
 orocos_kdl/orocos_kdl-config.cmake.in | 5 +----
 orocos_kdl/src/CMakeLists.txt         | 5 ++++-
 3 files changed, 6 insertions(+), 10 deletions(-)

diff --git a/orocos_kdl/CMakeLists.txt b/orocos_kdl/CMakeLists.txt
index a9d28e6..b63e8c4 100644
--- a/orocos_kdl/CMakeLists.txt
+++ b/orocos_kdl/CMakeLists.txt
@@ -51,10 +51,7 @@ ENDIF ( NOT CMAKE_BUILD_TYPE )
 
 SET( KDL_CFLAGS "")
 
-find_package(Eigen3 QUIET)
-if(NOT EIGEN3_FOUND)
-  include(${PROJ_SOURCE_DIR}/cmake/FindEigen3.cmake)
-endif()
+find_package(Eigen3 REQUIRED)
 include_directories(${EIGEN3_INCLUDE_DIR})
 SET(KDL_CFLAGS "${KDL_CFLAGS} -I\"${EIGEN3_INCLUDE_DIR}\"")
 
@@ -120,7 +117,6 @@ CONFIGURE_FILE(orocos_kdl-config.cmake.in
 CONFIGURE_FILE(orocos_kdl-config-version.cmake.in
   ${PROJECT_BINARY_DIR}/orocos_kdl-config-version.cmake @ONLY)
 
-INSTALL(FILES cmake/FindEigen3.cmake DESTINATION share/orocos_kdl/cmake)
 INSTALL(FILES ${PROJECT_BINARY_DIR}/orocos_kdl-config.cmake DESTINATION share/orocos_kdl/cmake)
 INSTALL(FILES ${PROJECT_BINARY_DIR}/orocos_kdl-config-version.cmake DESTINATION share/orocos_kdl/cmake)
 INSTALL(EXPORT OrocosKDLTargets DESTINATION share/orocos_kdl/cmake)
diff --git a/orocos_kdl/orocos_kdl-config.cmake.in b/orocos_kdl/orocos_kdl-config.cmake.in
index d17d433..282f8cd 100644
--- a/orocos_kdl/orocos_kdl-config.cmake.in
+++ b/orocos_kdl/orocos_kdl-config.cmake.in
@@ -8,10 +8,7 @@
 get_filename_component(orocos_kdl_PREFIX "${CMAKE_CURRENT_LIST_DIR}/../../.." ABSOLUTE)
 
 # Find dependencies
-find_package(Eigen3 QUIET)
-if(NOT EIGEN3_FOUND)
-  include(${CMAKE_CURRENT_LIST_DIR}/FindEigen3.cmake)
-endif()
+find_package(Eigen3 REQUIRED)
 
 set(KDL_USE_NEW_TREE_INTERFACE @KDL_USE_NEW_TREE_INTERFACE@)
 if(KDL_USE_NEW_TREE_INTERFACE)
diff --git a/orocos_kdl/src/CMakeLists.txt b/orocos_kdl/src/CMakeLists.txt
index 9e77e8e..485ea96 100644
--- a/orocos_kdl/src/CMakeLists.txt
+++ b/orocos_kdl/src/CMakeLists.txt
@@ -70,7 +70,10 @@ ENDIF()
 # Needed so that the generated config.h can be used
 TARGET_INCLUDE_DIRECTORIES(orocos-kdl PUBLIC
   "$<BUILD_INTERFACE:${CMAKE_CURRENT_BINARY_DIR}>")
-TARGET_LINK_LIBRARIES(orocos-kdl ${Boost_LIBRARIES})
+TARGET_LINK_LIBRARIES(orocos-kdl PUBLIC Eigen3::Eigen)
+if(KDL_USE_NEW_TREE_INTERFACE)
+    TARGET_LINK_LIBRARIES(orocos-kdl PUBLIC Boost::boost)
+endif()
 
 INSTALL(TARGETS orocos-kdl
   EXPORT OrocosKDLTargets
-- 
2.53.0.windows.3

